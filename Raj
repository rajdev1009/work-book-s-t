<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="EduBot-Pro is an AI-powered Telegram bot for Class 1–12 self-study, secure exams, adaptive learning, leaderboards, and admin-controlled assessments." />
  <title>EduBot-Pro | AI Telegram Bot for Smart Learning & Secure Exams</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    :root {
      --blue: #2563eb;
      --blue-dark: #1d4ed8;
      --blue-soft: #dbeafe;
      --purple: #7c3aed;
      --purple-dark: #5b21b6;
      --purple-soft: #ede9fe;
      --gold: #f6c453;
      --gold-soft: #fff4cc;
      --white: #ffffff;
      --ink: #101828;
      --muted: #667085;
      --line: #e6eaf2;
      --bg: #f7f9ff;
      --green: #10b981;
      --red: #ef4444;
      --shadow: 0 24px 70px rgba(37, 99, 235, 0.14);
      --shadow-soft: 0 14px 40px rgba(16, 24, 40, 0.08);
      --radius: 26px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 34rem),
        radial-gradient(circle at top right, rgba(124, 58, 237, 0.14), transparent 34rem),
        linear-gradient(180deg, #ffffff 0%, #f7f9ff 42%, #ffffff 100%);
      color: var(--ink);
      overflow-x: hidden;
      line-height: 1.6;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input {
      font-family: inherit;
    }

    .container {
      width: min(1180px, calc(100% - 40px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      padding: 14px 0;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(230, 234, 242, 0.78);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 900;
      letter-spacing: -0.03em;
      font-size: 1.2rem;
    }

    .logo {
      width: 44px;
      height: 44px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--blue), var(--purple));
      display: grid;
      place-items: center;
      color: white;
      box-shadow: 0 12px 30px rgba(37, 99, 235, 0.28);
      position: relative;
      overflow: hidden;
    }

    .logo::after {
      content: "";
      position: absolute;
      width: 28px;
      height: 28px;
      background: rgba(255, 255, 255, 0.18);
      border-radius: 50%;
      right: -8px;
      top: -7px;
    }

    .logo svg {
      width: 25px;
      height: 25px;
      position: relative;
      z-index: 2;
    }

    .navlinks {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .navlinks a {
      padding: 10px 13px;
      color: #475467;
      font-size: 0.94rem;
      font-weight: 700;
      border-radius: 999px;
      transition: 0.25s ease;
    }

    .navlinks a:hover {
      color: var(--blue);
      background: var(--blue-soft);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .btn {
      border: 0;
      border-radius: 999px;
      padding: 12px 18px;
      font-weight: 800;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      transition: 0.25s ease;
      white-space: nowrap;
    }

    .btn-primary {
      color: white;
      background: linear-gradient(135deg, var(--blue), var(--purple));
      box-shadow: 0 16px 36px rgba(37, 99, 235, 0.22);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 44px rgba(37, 99, 235, 0.3);
    }

    .btn-secondary {
      color: var(--blue-dark);
      background: white;
      border: 1px solid var(--line);
      box-shadow: 0 10px 24px rgba(16, 24, 40, 0.06);
    }

    .btn-secondary:hover {
      transform: translateY(-2px);
      border-color: rgba(37, 99, 235, 0.24);
      background: #f8fbff;
    }

    .menu-btn {
      display: none;
      width: 44px;
      height: 44px;
      border: 1px solid var(--line);
      border-radius: 15px;
      background: white;
      color: var(--ink);
      cursor: pointer;
    }

    .hero {
      position: relative;
      padding: 74px 0 70px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      align-items: center;
      gap: 48px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(37, 99, 235, 0.16);
      box-shadow: 0 12px 30px rgba(16, 24, 40, 0.06);
      color: var(--blue-dark);
      font-weight: 800;
      padding: 8px 13px;
      border-radius: 999px;
      margin-bottom: 20px;
      font-size: 0.9rem;
    }

    .spark {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: var(--gold);
      box-shadow: 0 0 0 6px rgba(246, 196, 83, 0.2);
    }

    h1 {
      font-size: clamp(2.55rem, 6vw, 5.4rem);
      line-height: 0.98;
      letter-spacing: -0.075em;
      font-weight: 900;
      margin-bottom: 24px;
    }

    .grad-text {
      background: linear-gradient(135deg, var(--blue), var(--purple) 62%, #c28a10);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      font-size: 1.12rem;
      color: var(--muted);
      max-width: 690px;
      margin-bottom: 28px;
    }

    .hero-ctas {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 28px;
    }

    .hero-proof {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 14px;
      color: #475467;
      font-size: 0.94rem;
      font-weight: 700;
    }

    .proof-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid var(--line);
      padding: 8px 12px;
      border-radius: 999px;
    }

    .proof-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--green);
    }

    .phone-wrap {
      position: relative;
    }

    .orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(0.2px);
      z-index: -1;
    }

    .orb.one {
      width: 170px;
      height: 170px;
      right: -30px;
      top: 10px;
      background: rgba(124, 58, 237, 0.16);
      animation: float 7s ease-in-out infinite;
    }

    .orb.two {
      width: 120px;
      height: 120px;
      left: -24px;
      bottom: 30px;
      background: rgba(246, 196, 83, 0.22);
      animation: float 8s ease-in-out infinite reverse;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-18px); }
    }

    .bot-card {
      position: relative;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid rgba(230, 234, 242, 0.92);
      border-radius: 34px;
      box-shadow: var(--shadow);
      padding: 18px;
      overflow: hidden;
    }

    .bot-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 18% 12%, rgba(37, 99, 235, 0.14), transparent 15rem),
        radial-gradient(circle at 85% 20%, rgba(124, 58, 237, 0.13), transparent 17rem);
      pointer-events: none;
    }

    .telegram-shell {
      position: relative;
      border-radius: 28px;
      background: #eef5ff;
      overflow: hidden;
      border: 1px solid rgba(37, 99, 235, 0.12);
    }

    .chat-head {
      background: linear-gradient(135deg, #2aabee, var(--blue));
      color: white;
      padding: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .bot-avatar {
      width: 48px;
      height: 48px;
      border-radius: 18px;
      background: white;
      color: var(--blue);
      display: grid;
      place-items: center;
      font-size: 1.35rem;
      font-weight: 900;
    }

    .chat-head strong {
      display: block;
      letter-spacing: -0.02em;
    }

    .chat-head span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.86rem;
      opacity: 0.92;
    }

    .chat-body {
      padding: 18px;
      display: grid;
      gap: 13px;
    }

    .bubble {
      max-width: 86%;
      padding: 12px 14px;
      border-radius: 18px;
      font-size: 0.94rem;
      box-shadow: 0 8px 18px rgba(16, 24, 40, 0.06);
    }

    .bubble.bot {
      background: white;
      border-top-left-radius: 6px;
      color: #26334d;
    }

    .bubble.user {
      background: linear-gradient(135deg, var(--blue), var(--purple));
      color: white;
      justify-self: end;
      border-top-right-radius: 6px;
    }

    .quiz-card {
      background: white;
      border-radius: 22px;
      padding: 16px;
      box-shadow: 0 18px 40px rgba(37, 99, 235, 0.12);
      border: 1px solid rgba(37, 99, 235, 0.1);
    }

    .quiz-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
      align-items: center;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border-radius: 999px;
      padding: 6px 10px;
      font-weight: 800;
      font-size: 0.78rem;
    }

    .tag.gold {
      background: var(--gold-soft);
      color: #9a6a00;
    }

    .tag.blue {
      background: var(--blue-soft);
      color: var(--blue-dark);
    }

    .timer {
      font-variant-numeric: tabular-nums;
      color: var(--red);
      font-weight: 900;
      background: #fff1f2;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 0.82rem;
    }

    .option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px;
      margin-top: 8px;
      border: 1px solid var(--line);
      border-radius: 14px;
      color: #475467;
      font-weight: 700;
    }

    .option.correct {
      border-color: rgba(16, 185, 129, 0.3);
      background: rgba(16, 185, 129, 0.08);
      color: #047857;
    }

    .check {
      width: 22px;
      height: 22px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--green);
      color: white;
      font-size: 0.75rem;
      flex: 0 0 auto;
    }

    .stats-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 28px;
    }

    .stat {
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 18px;
      box-shadow: var(--shadow-soft);
    }

    .stat strong {
      display: block;
      font-size: 1.72rem;
      letter-spacing: -0.04em;
      line-height: 1;
      color: var(--ink);
    }

    .stat span {
      color: var(--muted);
      font-weight: 700;
      font-size: 0.9rem;
    }

    section {
      padding: 74px 0;
    }

    .section-head {
      max-width: 760px;
      margin: 0 auto 38px;
      text-align: center;
    }

    .section-kicker {
      color: var(--blue-dark);
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.82rem;
      margin-bottom: 10px;
    }

    h2 {
      font-size: clamp(2rem, 4vw, 3.25rem);
      line-height: 1.06;
      letter-spacing: -0.06em;
      margin-bottom: 14px;
      font-weight: 900;
    }

    .section-head p {
      color: var(--muted);
      font-size: 1.05rem;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .feature-card {
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow-soft);
      transition: 0.28s ease;
      position: relative;
      overflow: hidden;
      min-height: 235px;
    }

    .feature-card::after {
      content: "";
      position: absolute;
      width: 120px;
      height: 120px;
      border-radius: 999px;
      right: -48px;
      top: -48px;
      background: rgba(37, 99, 235, 0.08);
      transition: 0.28s ease;
    }

    .feature-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 26px 60px rgba(37, 99, 235, 0.14);
      border-color: rgba(37, 99, 235, 0.22);
    }

    .feature-card:hover::after {
      transform: scale(1.25);
      background: rgba(124, 58, 237, 0.1);
    }

    .icon {
      width: 52px;
      height: 52px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--blue-soft), var(--purple-soft));
      color: var(--blue-dark);
      margin-bottom: 18px;
      position: relative;
      z-index: 2;
    }

    .icon.gold-icon {
      background: linear-gradient(135deg, var(--gold-soft), #fff);
      color: #b77900;
    }

    .feature-card h3 {
      font-size: 1.16rem;
      letter-spacing: -0.03em;
      margin-bottom: 8px;
      position: relative;
      z-index: 2;
    }

    .feature-card p {
      color: var(--muted);
      position: relative;
      z-index: 2;
    }

    .mode-section {
      background:
        linear-gradient(135deg, rgba(37, 99, 235, 0.08), rgba(124, 58, 237, 0.07)),
        #ffffff;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .split {
      display: grid;
      grid-template-columns: 0.92fr 1.08fr;
      gap: 26px;
      align-items: stretch;
    }

    .mode-card {
      background: white;
      border: 1px solid var(--line);
      border-radius: 30px;
      padding: 28px;
      box-shadow: var(--shadow-soft);
    }

    .mode-card h3 {
      font-size: 1.45rem;
      letter-spacing: -0.04em;
      margin-bottom: 10px;
    }

    .mode-card p {
      color: var(--muted);
      margin-bottom: 20px;
    }

    .timeline {
      display: grid;
      gap: 14px;
    }

    .timeline-item {
      display: grid;
      grid-template-columns: 38px 1fr;
      gap: 13px;
      align-items: start;
      padding: 14px;
      border-radius: 18px;
      background: #f8fbff;
      border: 1px solid rgba(37, 99, 235, 0.08);
    }

    .num {
      width: 38px;
      height: 38px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      color: white;
      background: linear-gradient(135deg, var(--blue), var(--purple));
      font-weight: 900;
    }

    .timeline-item strong {
      display: block;
      letter-spacing: -0.02em;
    }

    .timeline-item span {
      color: var(--muted);
      font-size: 0.93rem;
    }

    .admin-panel {
      background: #0f172a;
      color: white;
      border-radius: 30px;
      padding: 20px;
      box-shadow: 0 26px 80px rgba(15, 23, 42, 0.3);
      overflow: hidden;
    }

    .admin-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding-bottom: 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      margin-bottom: 16px;
    }

    .window-dots {
      display: flex;
      gap: 7px;
    }

    .window-dots i {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      display: block;
    }

    .window-dots i:nth-child(1) { background: #ff5f57; }
    .window-dots i:nth-child(2) { background: #ffbd2e; }
    .window-dots i:nth-child(3) { background: #28c840; }

    .admin-title {
      color: #cbd5e1;
      font-size: 0.88rem;
      font-weight: 800;
    }

    .command-search {
      width: 100%;
      padding: 13px 14px;
      border: 1px solid rgba(255, 255, 255, 0.11);
      background: rgba(255, 255, 255, 0.07);
      color: white;
      border-radius: 16px;
      outline: none;
      margin-bottom: 14px;
      font-weight: 700;
    }

    .command-search::placeholder {
      color: #94a3b8;
    }

    .commands {
      display: grid;
      gap: 10px;
      max-height: 430px;
      overflow: auto;
      padding-right: 4px;
    }

    .commands::-webkit-scrollbar {
      width: 8px;
    }

    .commands::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.18);
      border-radius: 999px;
    }

    .command {
      display: grid;
      grid-template-columns: 170px 1fr auto;
      gap: 12px;
      align-items: center;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 18px;
      padding: 13px;
      transition: 0.2s ease;
    }

    .command:hover {
      background: rgba(37, 99, 235, 0.2);
      border-color: rgba(96, 165, 250, 0.34);
    }

    code {
      color: #93c5fd;
      font-weight: 900;
      font-size: 0.92rem;
    }

    .command span {
      color: #cbd5e1;
      font-size: 0.9rem;
    }

    .copy-btn {
      border: 0;
      color: #0f172a;
      background: var(--gold);
      padding: 8px 10px;
      border-radius: 12px;
      font-weight: 900;
      cursor: pointer;
      transition: 0.2s ease;
    }

    .copy-btn:hover {
      transform: translateY(-1px);
      background: #ffd66b;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: 1.04fr 0.96fr;
      gap: 22px;
      align-items: start;
    }

    .dash-card {
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid var(--line);
      border-radius: 30px;
      box-shadow: var(--shadow);
      padding: 22px;
      overflow: hidden;
    }

    .dash-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .dash-head h3 {
      font-size: 1.22rem;
      letter-spacing: -0.04em;
    }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      color: #047857;
      background: rgba(16, 185, 129, 0.09);
      border: 1px solid rgba(16, 185, 129, 0.18);
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .mini-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 18px;
    }

    .mini {
      border-radius: 18px;
      padding: 14px;
      background: #f8fbff;
      border: 1px solid rgba(37, 99, 235, 0.08);
    }

    .mini strong {
      display: block;
      font-size: 1.45rem;
      letter-spacing: -0.04em;
    }

    .mini span {
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 800;
    }

    .chart-wrap {
      height: 260px;
      display: flex;
      align-items: end;
      gap: 12px;
      padding: 18px;
      background:
        linear-gradient(rgba(37, 99, 235, 0.06) 1px, transparent 1px),
        #ffffff;
      background-size: 100% 52px;
      border-radius: 22px;
      border: 1px solid var(--line);
    }

    .bar {
      flex: 1;
      border-radius: 14px 14px 8px 8px;
      min-height: 28px;
      background: linear-gradient(180deg, var(--purple), var(--blue));
      position: relative;
      transform-origin: bottom;
      animation: grow 1.1s ease both;
      box-shadow: 0 12px 22px rgba(37, 99, 235, 0.18);
    }

    .bar:nth-child(even) {
      background: linear-gradient(180deg, var(--gold), var(--blue));
    }

    .bar::after {
      content: attr(data-label);
      position: absolute;
      bottom: -24px;
      left: 50%;
      transform: translateX(-50%);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 900;
    }

    @keyframes grow {
      from { transform: scaleY(0.2); opacity: 0.4; }
      to { transform: scaleY(1); opacity: 1; }
    }

    .leaderboard {
      display: grid;
      gap: 12px;
    }

    .rank-row {
      display: grid;
      grid-template-columns: 42px 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 13px;
      border-radius: 18px;
      background: #f8fbff;
      border: 1px solid rgba(37, 99, 235, 0.08);
    }

    .rank {
      width: 42px;
      height: 42px;
      border-radius: 15px;
      display: grid;
      place-items: center;
      background: var(--purple-soft);
      color: var(--purple-dark);
      font-weight: 900;
    }

    .rank.gold-rank {
      background: var(--gold-soft);
      color: #a16207;
    }

    .student strong {
      display: block;
      letter-spacing: -0.02em;
    }

    .student span {
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 700;
    }

